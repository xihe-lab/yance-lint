<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <!-- ESLint Annotator -->
        <externalAnnotator language="JavaScript"
                           implementationClass="com.xihe_lab.yance.idea.eslint.EsLintAnnotator"
        />
        <externalAnnotator language="TypeScript"
                           implementationClass="com.xihe_lab.yance.idea.eslint.EsLintAnnotator"
        />

        <!-- Stylelint Annotator -->
        <externalAnnotator language="CSS"
                           implementationClass="com.xihe_lab.yance.idea.stylelint.StylelintAnnotator"
        />
        <!-- Gutter Icons -->
        <codeInsight.lineMarkerProvider language="JavaScript"
                                        implementationClass="com.xihe_lab.yance.idea.lint.gutter.YanceGutterLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider language="TypeScript"
                                        implementationClass="com.xihe_lab.yance.idea.lint.gutter.YanceGutterLineMarkerProvider"
        />
        <codeInsight.lineMarkerProvider language="CSS"
                                        implementationClass="com.xihe_lab.yance.idea.lint.gutter.YanceGutterLineMarkerProvider"
        />
    </extensions>

</idea-plugin>
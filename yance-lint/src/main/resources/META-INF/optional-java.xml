<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">

        <!-- P3C Naming Inspections -->
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.P3cNamingInspection"
                         shortName="p3c-naming-inspection"
                         displayName="P3C 命名检查"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
                         hasStaticDescription="true"
        />
        <!-- P3C Standalone Inspections (yance-p3c module) -->
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.WrapperTypeEqualityInspection"
                         shortName="p3c-wrapper-type-equality"
                         displayName="包装类型使用 equals 比较"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.EqualsAvoidNullInspection"
                         shortName="p3c-equals-avoid-null"
                         displayName="equals 常量放左侧"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AccessStaticViaInstanceInspection"
                         shortName="p3c-access-static-via-instance"
                         displayName="避免通过实例访问静态成员"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.ControlFlowStatementWithoutBracesInspection"
                         shortName="p3c-control-flow-braces"
                         displayName="控制语句必须使用大括号"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.ArrayNamingShouldHaveBracketInspection"
                         shortName="p3c-array-naming-bracket"
                         displayName="数组声明使用 Type[] 形式"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.LongLiteralsEndingWithLowercaseLInspection"
                         shortName="p3c-long-literal-uppercase"
                         displayName="long 常量使用大写 L"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.MissingOverrideAnnotationInspection"
                         shortName="p3c-missing-override"
                         displayName="覆写方法必须加 @Override"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.MapOrSetKeyShouldOverrideHashCodeEqualsInspection"
                         shortName="p3c-map-set-hashcode-equals"
                         displayName="Map/Set key 必须重写 hashCode 和 equals"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.DeprecationInspection"
                         shortName="p3c-deprecation"
                         displayName="禁止使用已过时的 API"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <!-- P3C Extended Inspections -->
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.SubListCastToArrayListInspection"
                         shortName="p3c-sublist-cast"
                         displayName="subList 结果不可强转 ArrayList"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.ThreadPoolCreationInspection"
                         shortName="p3c-thread-pool"
                         displayName="不要显式创建线程"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AvoidManuallyCreateThreadPoolInspection"
                         shortName="p3c-executors-create"
                         displayName="不要使用 Executors 创建线程池"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AvoidCatchNullPointerExceptionInspection"
                         shortName="p3c-catch-npe"
                         displayName="避免捕获 NullPointerException"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AvoidStartWithClassNameConstructorInspection"
                         shortName="p3c-method-same-as-class"
                         displayName="方法名不应与类名相同"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AvoidDoubleOrFloatEqualCompareInspection"
                         shortName="p3c-float-equal"
                         displayName="浮点数比较不要用 =="
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.EqualsAndHashCodeMustBePairedInspection"
                         shortName="p3c-equals-hashcode-pair"
                         displayName="equals/hashCode 必须成对覆写"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.AvoidBigDecimalEqualsInspection"
                         shortName="p3c-bigdecimal-equals"
                         displayName="BigDecimal 比较用 compareTo"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <localInspection implementationClass="com.xihe_lab.yance.idea.p3c.inspection.StringBuilderInitWithCharInspection"
                         shortName="p3c-stringbuilder-char"
                         displayName="StringBuilder 不要传 char 参数"
                         groupName="P3C"
                         language="JAVA"
                         level="WARNING"
                         enabledByDefault="true"
        />
        <!-- Checkstyle Annotator -->
        <externalAnnotator language="JAVA"
                           implementationClass="com.xihe_lab.yance.idea.checkstyle.CheckstyleAnnotator"
        />
        <!-- Gutter Icon -->
        <codeInsight.lineMarkerProvider language="JAVA"
                                        implementationClass="com.xihe_lab.yance.idea.lint.gutter.YanceGutterLineMarkerProvider"
        />
    </extensions>

</idea-plugin>